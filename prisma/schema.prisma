generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GenerationStatus {
  QUEUED
  PROCESSING_TEXT
  PROCESSING_IMAGES
  COMPLETED
  FAILED
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum AssetType {
  IMAGE
}

model GenerationRun {
  id                String           @id @default(cuid())
  prompt            String
  style             String?
  language          String           @default("en")
  durationTargetSec Int              @default(30)
  imageCount        Int              @default(4)
  voice             String           @default("alloy")
  status            GenerationStatus @default(QUEUED)
  errorMessage      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  script Script?
  jobs   Job[]
  assets Asset[]
}

model Script {
  id              String   @id @default(cuid())
  generationRunId String   @unique
  title           String
  hook            String
  fullScript      String
  voiceoverText   String
  rawJson         Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  generationRun GenerationRun @relation(fields: [generationRunId], references: [id], onDelete: Cascade)
  scenes        Scene[]
}

model Scene {
  id          String   @id @default(cuid())
  scriptId    String
  sceneNumber Int
  narration   String
  imagePrompt String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  assets Asset[]

  @@unique([scriptId, sceneNumber])
}

model Asset {
  id              String    @id @default(cuid())
  generationRunId String
  sceneId         String?
  type            AssetType
  storagePath     String
  publicUrl       String
  mimeType        String    @default("image/png")
  createdAt       DateTime  @default(now())

  generationRun GenerationRun @relation(fields: [generationRunId], references: [id], onDelete: Cascade)
  scene         Scene?         @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@index([generationRunId, type])
  @@index([sceneId])
}

model Job {
  id              String    @id @default(cuid())
  generationRunId String
  type            String
  status          JobStatus @default(QUEUED)
  attemptCount    Int       @default(0)
  errorMessage    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  generationRun GenerationRun @relation(fields: [generationRunId], references: [id], onDelete: Cascade)
}